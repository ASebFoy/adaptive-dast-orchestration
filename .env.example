# =============================================================================
# Environment Variables for Thesis Experiment
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# OpenAI API — required for the ReAct agent (GPT-4o)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OWASP ZAP API key (must match docker-compose.yml)
ZAP_API_KEY=thesis-zap-api-key

# Target URLs
# Docker-internal URL (used by scripts running inside the network)
TARGET_URL=http://juice-shop:3000
# Host URL (used by scripts running on the host machine)
HOST_TARGET_URL=http://localhost:3000

# ZAP proxy URL
ZAP_URL=http://localhost:8080

# Juice Shop test user credentials (provisioned by setup_user.py)
TEST_USER_EMAIL=test@juice-sh.op
TEST_USER_PASSWORD=test123
